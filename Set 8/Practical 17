import java.io.*;
import java.util.Date;

public class Pra17 {

    static void showDetails(File f) {
        System.out.println("\n--- File Details ---");
        System.out.println("Name: " + f.getName());
        System.out.println("Path: " + f.getAbsolutePath());
        System.out.println("Size: " + f.length() + " bytes");
        System.out.println("Readable: " + f.canRead());
        System.out.println("Writable: " + f.canWrite());
        System.out.println("Last Modified: " + new Date(f.lastModified()));
    }

    public static void main(String[] args) {

        if (args.length < 2) {
            System.out.println("Usage:");
            System.out.println("Copy: java FileOperationsApp copy source.txt dest.txt");
            System.out.println("Delete: java FileOperationsApp delete file.txt");
            System.out.println("Rename: java FileOperationsApp rename old.txt new.txt");
            return;
        }

        String command = args[0];

        try {
            if (command.equalsIgnoreCase("copy")) {

                File src = new File(args[1]);
                File dest = new File(args[2]);

                if (!src.exists()) {
                    throw new FileNotFoundException("Source file not found");
                }

                FileInputStream fis = new FileInputStream(src);
                FileOutputStream fos = new FileOutputStream(dest);

                int ch;
                while ((ch = fis.read()) != -1) {
                    fos.write(ch);
                }

                fis.close();
                fos.close();

                System.out.println("File copied successfully.");
                showDetails(dest);

            } else if (command.equalsIgnoreCase("delete")) {

                File file = new File(args[1]);

                if (!file.exists()) {
                    throw new FileNotFoundException("File not found");
                }

                if (file.delete()) {
                    System.out.println("File deleted successfully.");
                } else {
                    System.out.println("Unable to delete file.");
                }

            } else if (command.equalsIgnoreCase("rename")) {

                File oldFile = new File(args[1]);
                File newFile = new File(args[2]);

                if (!oldFile.exists()) {
                    throw new FileNotFoundException("File not found");
                }

                if (oldFile.renameTo(newFile)) {
                    System.out.println("File renamed successfully.");
                    showDetails(newFile);
                } else {
                    System.out.println("Rename failed.");
                }

            } else {
                System.out.println("Invalid command.");
            }

        } catch (FileNotFoundException e) {
            System.out.println("Error: " + e.getMessage());
        } catch (IOException e) {
            System.out.println("IO Error: " + e.getMessage());
        }
    }
}
