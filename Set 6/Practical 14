public class pra14 {

    public static double average(String[] arr) throws NullPointerException, NumberFormatException {
        double total = 0;

        for (int i = 0; i < arr.length; i++) {
            if (arr[i] == null) {
                throw new NullPointerException("Element at index " + i + " is null");
            }

            double num = Double.valueOf(arr[i]);
            total += num;
        }

        return total / arr.length;
    }

    public static void main(String[] args) {

        String[] data1 = {"5.5", "10.5", "14"};
        String[] data2 = {"7", "xyz", "21"};
        String[] data3 = {"9", null, "18"};

        try {
            double result = average(data1);
            System.out.println("Average of data1 = " + result);
        } catch (Exception e) {
            System.out.println("Error: " + e);
        } finally {
            System.out.println("Test 1 completed\n");
        }

        try {
            double result = average(data2);
            System.out.println("Average of data2 = " + result);
        } catch (NumberFormatException e) {
            System.out.println("Invalid number found: " + e.getMessage());
        } catch (NullPointerException e) {
            System.out.println("Null detected: " + e.getMessage());
        } finally {
            System.out.println("Test 2 completed\n");
        }

        try {
            double result = average(data3);
            System.out.println("Average of data3 = " + result);
        } catch (NumberFormatException e) {
            System.out.println("Invalid number found: " + e.getMessage());
        } catch (NullPointerException e) {
            System.out.println("Null detected: " + e.getMessage());
        } finally {
            System.out.println("Test 3 completed");
        }
    }
}
